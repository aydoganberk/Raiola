{
  "name": "raiola",
  "version": "0.4.8",
  "private": false,
  "description": "raiola is a repo-native workflow OS for Codex with natural-language routing, review orchestration, prompt packs, and closeout tooling.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aydoganberk/Raiola.git"
  },
  "homepage": "https://github.com/aydoganberk/Raiola#readme",
  "bugs": {
    "url": "https://github.com/aydoganberk/Raiola/issues"
  },
  "keywords": [
    "codex",
    "workflow",
    "cli",
    "developer-tools",
    "review",
    "monorepo",
    "orchestration"
  ],
  "bin": {
    "rai": "bin/rai.js",
    "raiola": "bin/raiola.js",
    "raiola-on": "bin/raiola-on.js",
    "raiola-mcp": "bin/raiola-mcp.js"
  },
  "files": [
    "bin",
    "scripts",
    "skill",
    "skills",
    "agents",
    "references",
    "hooks",
    "templates",
    ".claude",
    ".claude-plugin",
    "docs/architecture.md",
    "docs/codex-integration.md",
    "docs/codex-upgrade.md",
    "docs/commands.md",
    "docs/control-planes.md",
    "docs/getting-started.md",
    "docs/quickstart.md",
    "docs/workflow-bundles.md",
    "docs/performance.md",
    "docs/roadmap-audit.md",
    "docs/contracts",
    "schemas",
    ".workflowignore",
    "AGENTS.md",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "SECURITY.md",
    ".codex",
    ".agents/plugins",
    "plugins",
    ".github/codex",
    ".github/workflows/codex-review.yml",
    "docs/codex-orchestration.md",
    "docs/codex-operator-layer.md"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "release:cut": "node scripts/release/cut_release.js",
    "release:notes": "node scripts/release/release_notes_from_changelog.js",
    "test": "node --test tests/*.test.js",
    "pack:smoke": "node scripts/smoke_pack_install.js --pack",
    "rai": "node bin/rai.js",
    "raiola-on": "node bin/raiola-on.js",
    "rai:help": "node bin/rai.js help",
    "rai:quickstart": "node bin/rai.js help quickstart",
    "rai:start": "node bin/rai.js start",
    "rai:do": "node bin/rai.js do",
    "rai:next": "node bin/rai.js next",
    "rai:verify": "node bin/rai.js verify",
    "rai:doctor": "node bin/rai.js doctor",
    "rai:audit-repo": "node bin/rai.js audit-repo",
    "rai:api-surface": "node bin/rai.js api-surface",
    "rai:repo-proof": "node bin/rai.js repo-proof"
  }
}
