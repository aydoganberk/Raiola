    },
    "generatedArtifactRoots": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "generatedArtifactFiles": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": true
}
