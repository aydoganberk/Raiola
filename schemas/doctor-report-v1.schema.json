{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "raiola/doctor-report/v1",
  "type": "object",
  "required": [
    "schema",
    "contractVersion",
    "failCount",
    "warnCount",
    "checks",
    "compatibility"
  ],
  "properties": {
    "schema": {
      "const": "raiola/doctor-report/v1"
    },
    "contractVersion": {
      "type": "string"
    },
    "failCount": {
      "type": "integer"
    },
    "warnCount": {
      "type": "integer"
    },
    "checks": {
      "type": "array"
    },
    "risk": {
      "type": "object"
    },
    "compatibility": {
      "type": "object"
    }
  },
  "additionalProperties": true
}
